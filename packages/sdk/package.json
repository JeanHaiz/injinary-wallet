{
	"name": "@ai-wallet/sdk",
	"version": "0.0.1",
	"description": "SDK for web apps to interact with the AI Wallet browser extension",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {},
	"devDependencies": {
		"@ai-wallet/shared": "workspace:*",
		"tsup": "^8.3.0",
		"vitest": "^2.1.0"
	},
	"sideEffects": false,
	"license": "MIT"
}
