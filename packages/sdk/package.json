{
	"name": "@injinary-wallet/sdk",
	"version": "0.0.2",
	"description": "SDK for web apps to interact with the Injinary Wallet browser extension",
	"author": "Injinary <injinary@gmail.com>",
	"license": "MIT",
	"homepage": "https://github.com/JeanHaiz/injinary-wallet#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JeanHaiz/injinary-wallet.git",
		"directory": "packages/sdk"
	},
	"bugs": {
		"url": "https://github.com/JeanHaiz/injinary-wallet/issues"
	},
	"keywords": [
		"ai",
		"api-keys",
		"wallet",
		"browser-extension",
		"openai",
		"anthropic",
		"sdk",
		"injinary"
	],
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {},
	"devDependencies": {
		"@injinary-wallet/shared": "workspace:*",
		"tsup": "^8.3.0",
		"vitest": "^2.1.0"
	},
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	}
}